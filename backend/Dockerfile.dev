FROM node:18-alpine AS development

# Set working directory
WORKDIR /app

# Install development dependencies and tools
RUN apk add --no-cache \
    curl \
    bash \
    git \
    python3 \
    make \
    g++ \
    && npm install -g \
    nodemon \
    @nestjs/cli \
    typescript \
    ts-node

# Create a non-root user and group
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# Set environment variables
ENV NODE_ENV=development
ENV PORT=4000
ENV TZ=UTC

# Copy package.json and package-lock.json first for better caching
COPY package*.json ./

# Install dependencies using the exact versions from package-lock.json
RUN npm ci

# Copy the rest of the application code
# Note: In dev mode, this will typically be overridden by a volume mount
COPY . .

# Set proper permissions
RUN chown -R appuser:appgroup /app

# Switch to non-root user
USER appuser

# Expose debugging port and application port
EXPOSE 4000 9229

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:4000/api/health || exit 1

# Start the application in development mode with hot reload and debugging enabled
CMD ["npm", "run", "start:debug"]
