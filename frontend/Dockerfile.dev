FROM node:18-alpine AS development

# Set working directory
WORKDIR /app

# Install development dependencies and tools
RUN apk add --no-cache \
    curl \
    bash \
    git \
    python3 \
    make \
    g++ \
    && npm install -g \
    vite \
    typescript \
    eslint

# Create a non-root user and group
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# Set environment variables
ENV NODE_ENV=development
ENV PORT=3000
ENV VITE_HOST=0.0.0.0
ENV VITE_PORT=3000
ENV VITE_HMR_HOST=0.0.0.0
ENV VITE_HMR_PORT=24678
ENV TZ=UTC

# Copy package.json and package-lock.json first for better caching
COPY package*.json ./

# Install dependencies using the exact versions from package-lock.json
RUN npm ci

# Copy the rest of the application code
# Note: In dev mode, this will typically be overridden by a volume mount
COPY . .

# Set proper permissions
RUN chown -R appuser:appgroup /app

# Switch to non-root user
USER appuser

# Expose Vite dev server port and HMR port
EXPOSE 3000 24678

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:3000/ || exit 1

# Start the Vite development server with HMR enabled
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
