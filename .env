# MarineAI - Environment Variables
# Copy this file to .env and fill in your values

# ===== GENERAL =====
NODE_ENV=development                     # development, staging, production
PORT=3000                                # API port
FRONTEND_URL=http://localhost:8080       # Used for CORS configuration

# ===== DATABASE =====
POSTGRES_USER=postgres                   # Database username
POSTGRES_PASSWORD=postgres               # Database password
POSTGRES_DB=marineai                     # Database name
DATABASE_URL=postgres://postgres:postgres@postgres:5432/marineai

# ===== REDIS =====
REDIS_URL=redis://redis:6379             # Redis connection URL
REDIS_PASSWORD=                          # Optional: Redis password

# ===== JWT AUTH =====
JWT_SECRET=development_secret            # Secret for signing JWT tokens
JWT_REFRESH_SECRET=development_refresh_secret  # Secret for refresh tokens
JWT_EXPIRES_IN=1h                        # Access token expiration
REFRESH_TOKEN_EXPIRES_IN=7d              # Refresh token expiration

# ===== OBJECT STORAGE (S3/MINIO) =====
MINIO_ROOT_USER=minioadmin               # MinIO admin username
MINIO_ROOT_PASSWORD=minioadmin           # MinIO admin password
S3_ENDPOINT=http://minio:9000            # S3-compatible endpoint
S3_ACCESS_KEY=minioadmin                 # S3 access key
S3_SECRET_KEY=minioadmin                 # S3 secret key
S3_BUCKET_MANUALS=manuals                # Bucket for vessel manuals
S3_BUCKET_THUMBNAILS=thumbnails          # Bucket for thumbnails
S3_BUCKET_OCR=ocr                        # Bucket for OCR results

# ===== AI SERVICE =====
OPENAI_API_KEY=                          # OpenAI API key for embeddings and RAG
AI_SERVICE_URL=http://ai-service:8000    # URL to the AI service
AI_MODEL=gpt-4o                          # Default AI model to use
AI_EMBEDDING_MODEL=text-embedding-3-large # Embedding model
AI_MAX_TOKENS=8192                       # Max tokens for context window
AI_TEMPERATURE=0.2                       # Temperature for AI responses

# ===== VECTOR DATABASE =====
WEAVIATE_URL=http://weaviate:8080        # Weaviate endpoint
WEAVIATE_API_KEY=                        # Optional: Weaviate API key if auth enabled

# ===== OCR =====
OCR_CONFIDENCE_THRESHOLD=85              # Threshold for flagging low-quality scans
OCR_DPI=300                              # DPI for OCR processing
OCR_LANGUAGE=eng                         # Default OCR language

# ===== MONITORING =====
SENTRY_DSN=                              # Optional: Sentry DSN for error tracking
LOG_LEVEL=info                           # debug, info, warn, error
ENABLE_TELEMETRY=true                    # Enable anonymous usage statistics

# ===== SECURITY =====
CORS_ALLOWED_ORIGINS=http://localhost:8080  # Comma-separated list of allowed origins
RATE_LIMIT_WINDOW=15m                    # Rate limiting window
RATE_LIMIT_MAX=100                       # Max requests per window
